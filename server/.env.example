# Server Configuration
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/kanban_db?schema=public"

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_access_token_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_token_key_min_32_chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info